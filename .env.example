# ===== LLM provider =====
# DashScope API key (Anthropic-compatible endpoint)
ANTHROPIC_API_KEY=

# DashScope Anthropic-compatible endpoint URL
ANTHROPIC_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic

# Strong-reasoning model for persona/extraction tasks
LLM_MODEL_PRIMARY=qwen3-max

# Cheaper fallback model on rate-limit or retryable failure
LLM_MODEL_FALLBACK=qwen3-coder-plus

# ===== Agent runtime =====
# Max fix attempts per (batch_id, layer, error_kind)
AGENT_RETRY_BUDGET=3

# Max LLM diagnose calls per loop iteration
AGENT_DIAGNOSE_BUDGET=10

# Seconds between run_once iterations in run_forever
AGENT_LOOP_INTERVAL=60.0

# Filesystem lock path (PID + stale detection)
AGENT_LOCK_PATH=state/agent.lock

# ===== Pipeline processing =====
# Max retry attempts per LLM call before fallback
PIPELINE_RETRY_BUDGET=3

# Agent loop sleep interval (used in F4/F5)
PIPELINE_LOOP_SLEEP_SECONDS=60

# Hard cap on LLM calls per Silver batch
PIPELINE_LLM_MAX_CALLS_PER_BATCH=5000

# Max in-flight LLM calls per batch (persona lane)
PIPELINE_LLM_CONCURRENCY=16

# ===== Storage =====
# SQLite manifest database path (relative paths resolve against repo root)
PIPELINE_STATE_DB=state/manifest.db

# Bronze layer output directory
BRONZE_ROOT=data/bronze

# Silver layer output directory
SILVER_ROOT=data/silver

# Gold layer output directory
GOLD_ROOT=data/gold

# ===== Logging =====
# Log level (DEBUG | INFO | WARNING | ERROR | CRITICAL)
PIPELINE_LOG_LEVEL=INFO

# Log format (json for production, console for development)
LOG_FORMAT=json

# ===== Silver layer secrets =====
# HMAC-SHA256 key for stable lead_id hashing (generate: openssl rand -hex 32)
PIPELINE_LEAD_SECRET=
