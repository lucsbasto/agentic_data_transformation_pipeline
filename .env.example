# Copy this file to .env and fill in real values. Never commit .env.
# .env is gitignored; .env.example is the public template.

# -----------------------------------------------------------------------------
# LLM provider
# -----------------------------------------------------------------------------
# We use the Anthropic Python SDK pointed at DashScope's Anthropic-compatible
# endpoint. The SDK reads ANTHROPIC_API_KEY by default, so we reuse that name
# for the DashScope key (no custom client wiring needed).
ANTHROPIC_API_KEY=sk-replace-with-your-dashscope-key

# Override the default https://api.anthropic.com base URL to hit DashScope.
ANTHROPIC_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic

# Primary model: strong reasoning (persona classification, analytics extraction).
LLM_MODEL_PRIMARY=qwen3-max

# Fallback model: cheaper, used on rate-limit or primary failure.
LLM_MODEL_FALLBACK=qwen3-coder-plus

# -----------------------------------------------------------------------------
# Pipeline runtime (see PRD §16 ADRs)
# -----------------------------------------------------------------------------
PIPELINE_RETRY_BUDGET=3
PIPELINE_LOOP_SLEEP_SECONDS=60
PIPELINE_STATE_DB=state/manifest.db
PIPELINE_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Silver layer secrets (F2)
# -----------------------------------------------------------------------------
# HMAC-SHA256 key used to turn the normalized phone number into a stable
# lead_id in the Silver layer. Must be at least 16 bytes of cryptographic
# entropy. Generate locally with: ``openssl rand -hex 32``.
# Rotating this value re-hashes every lead_id on the next Silver run, so keep
# it stable across runs you want to join on.
PIPELINE_LEAD_SECRET=replace-with-openssl-rand-hex-32
